{
  "name": "elara",
  "version": "1.0.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "AI-powered developer productivity desktop app with CLI integration for commit message generation and more",
  "bin": {
    "elara": "./cli/bin/run.js"
  },
  "files": [
    "bin",
    "src",
    "resources",
    "out",
    "package.json",
    "electron.vite.config.ts"
  ],
  "main": "./out/main/index.js",
  "author": "KhanhRomVN",
  "scripts": {
    "dev": "npm run tauri -- dev",
    "frontend": "vite",
    "dev:server": "cd backend && npm run dev",
    "watch:server": "tail -f server.log",
    "build:frontend": "vite build",
    "build:linux": "tauri build",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc --runner cargo-xwin",
    "collect:dist": "node scripts/collect-artifacts.js",
    "build": "npm run build:linux && npm run build:windows && npm run collect:dist",
    "preview": "npm run tauri preview",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/dev-setup.js",
    "setup-cli": "node scripts/dev-setup.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "@tanstack/query-sync-storage-persister": "^5.90.22",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "country-flag-icons": "^1.6.12",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.29.0",
    "fuse.js": "^7.1.0",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^3.6.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "simple-git": "^3.30.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.0.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "vscode-icons-js": "^11.6.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.3",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'echo \"🔍 Running ESLint...\"'",
      "eslint --fix",
      "bash -c 'echo \"✨ Running Prettier...\"'",
      "prettier --write",
      "bash -c 'echo \"🔧 Running TypeScript compiler check...\"'",
      "bash -c 'tsc --noEmit -p tsconfig.json'",
      "bash -c 'echo \"🛡️  Running njsscan security scan...\" && /home/khanhromvn/.local/bin/njsscan --sarif --output njsscan.sarif . || true'"
    ],
    "*.{json,css,md}": [
      "bash -c 'echo \"✨ Running Prettier...\"'",
      "prettier --write"
    ],
    "*": [
      "bash -c 'echo \"🔐 Running secretlint...\"'",
      "secretlint --maskSecrets",
      "bash -c 'echo \"🛡️  Running GitGuardian (ggshield)...\" && /home/khanhromvn/.local/bin/ggshield secret scan pre-commit --exit-zero || true'",
      "bash -c 'echo \"🔍 Running Gitleaks...\" && /home/khanhromvn/.local/bin/gitleaks protect --staged --redact --verbose || true'",
      "bash -c 'echo \"🔒 Running Talisman...\" && /home/khanhromvn/.local/bin/talisman --pattern staged || true'"
    ]
  }
}
