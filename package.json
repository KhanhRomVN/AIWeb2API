{
  "name": "@khanhromvn/elara-server",
  "version": "1.2.5",
  "description": "Elara Backend Server",
  "main": "dist/start.js",
  "bin": {
    "elara-server": "dist/start.js"
  },
  "files": [
    "dist"
  ],
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-win-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist-bin"
  },
  "scripts": {
    "dev": "nodemon",
    "start": "ts-node --transpile-only -r tsconfig-paths/register -r dotenv/config src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "prepare": "husky",
    "obfuscate": "javascript-obfuscator ./dist --output ./dist --compact true --self-defending false --string-array false --exclude \"**/services/db.js,**/utils/database.js\"",
    "build": "tsc && tsc-alias && mkdir -p dist/provider && cp src/provider/*.wasm dist/provider/ && npm run obfuscate || true",
    "build:min": "tsup",
    "build:bin": "rm -rf dist dist-bin && BUILD_SQLITE_BINDING=true npm run build && npm rebuild better-sqlite3 --target=18.0.0 --target_arch=x64 --target_platform=linux --update-binary && pkg . && cp node_modules/better-sqlite3/build/Release/better_sqlite3.node dist-bin/ && npm rebuild better-sqlite3",
    "commit": "commit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.0.1",
    "fastq": "^1.20.1",
    "fs-extra": "^11.3.3",
    "helmet": "^8.1.0",
    "http-mitm-proxy": "^1.1.0",
    "ignore": "^7.0.5",
    "js-tiktoken": "^1.0.21",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.1",
    "multer": "^2.0.2",
    "node-fetch": "^2.7.0",
    "simple-git": "^3.31.1",
    "sqlite3": "^5.1.7",
    "tough-cookie": "^6.0.0",
    "winston": "^3.17.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@arcjet/node": "^1.0.0-beta.4",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@lancedb/lancedb": "^0.26.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chokidar": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.30",
    "@types/node-fetch": "^2.6.13",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "javascript-obfuscator": "^5.3.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.0",
    "nodemon": "^3.1.4",
    "pkg": "^5.8.1",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1"
  }
}
